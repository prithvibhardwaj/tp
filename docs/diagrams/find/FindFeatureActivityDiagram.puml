@startuml
start
:User enters a find command;
:AddressBookParser selects matching parser;
:Trim input;
if () then ([at least 1 keyword])
  :Split by whitespace;
  :Validate each keyword
  against [\\p{Alnum}\\-'/.]+;
  if () then ([all keywords valid])
    :Create NameContainsKeywordsPredicate;
    :Execute Find*Command;
    if () then ([command is find])
      :Store selected trainer (if any);
      :updateFilteredPersonList(predicate);
      :Re-apply selected trainer
      (keeps client list filtered);
    else ([find-t or find-c])
      :updateFilteredTrainerList or
      updateFilteredClientList;
    endif
    :UI updates filtered lists;
  else ([invalid keyword found])
    :Show invalid command format;
  endif
else ([no keywords provided])
  :Show invalid command format;
endif
stop
@enduml
