<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<HBox id="cardPane" fx:id="cardPane" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
  <GridPane HBox.hgrow="ALWAYS">
    <columnConstraints>
      <ColumnConstraints hgrow="SOMETIMES" minWidth="10" prefWidth="150" />
    </columnConstraints>
    <VBox alignment="CENTER_LEFT" minHeight="105" spacing="4" GridPane.columnIndex="0">
      <padding>
        <Insets top="5" right="5" bottom="5" left="15" />
      </padding>
      <HBox spacing="5" alignment="CENTER_LEFT">
        <Label fx:id="id" styleClass="cell_big_label">
          <minWidth>
            <!-- Ensures that the label text is never truncated -->
            <Region fx:constant="USE_PREF_SIZE" />
          </minWidth>
        </Label>
        <Label fx:id="personIcon" />
        <Label fx:id="name" text="\$first" styleClass="cell_big_label" />
      </HBox>
      <FlowPane fx:id="tags" id="tags" />

      <Label fx:id="phone" styleClass="cell_small_label card-info" text="\$phone">
        <graphic>
          <SVGPath styleClass="card-icon" scaleX="0.85" scaleY="0.85"
                   content="M5 1 H11 A2 2 0 0 1 13 3 V13 A2 2 0 0 1 11 15 H5 A2 2 0 0 1 3 13 V3 A2 2 0 0 1 5 1 Z M6 3 H10 V4 H6 Z M7 12 H9 V13 H7 Z" />
        </graphic>
      </Label>

      <Label fx:id="role" styleClass="cell_small_label" />

      <Label fx:id="email" styleClass="cell_small_label card-info">
        <graphic>
          <SVGPath styleClass="card-icon" scaleX="0.85" scaleY="0.85"
                   content="M2 4 H14 V12 H2 Z M3 5 L8 9 L13 5 V6 L8 10 L3 6 Z" />
        </graphic>
      </Label>

      <Label fx:id="clientCount" styleClass="cell_small_label card-info client-count">
        <graphic>
          <SVGPath styleClass="card-icon" scaleX="0.85" scaleY="0.85"
                   content="M6 7 A2 2 0 1 1 6 3 A2 2 0 1 1 6 7 Z M12 7 A2 2 0 1 1 12 3 A2 2 0 1 1 12 7 Z M2 14 C2 11 4.5 10 6 10 C7.5 10 10 11 10 14 Z M8 14 C8 11 10.5 10 12 10 C13.5 10 16 11 16 14 Z" />
        </graphic>
      </Label>

      <Label fx:id="assignedTrainer" styleClass="cell_small_label card-info">
        <graphic>
          <SVGPath styleClass="card-icon" scaleX="0.85" scaleY="0.85"
                   content="M8 8 A3 3 0 1 1 8 2 A3 3 0 1 1 8 8 Z M2 14 C2 11 5 10 8 10 C11 10 14 11 14 14 Z" />
        </graphic>
      </Label>

      <Label fx:id="calorieInfo" styleClass="cell_small_label card-info">
        <graphic>
          <SVGPath styleClass="card-icon" scaleX="0.85" scaleY="0.85"
                   content="M8 1 C6 4 10 5 8 8 C6 6 4 8 4 10 C4 13 6 15 8 15 C10 15 12 13 12 10 C12 7 10 6 10 4 C10 3 9 2 8 1 Z" />
        </graphic>
      </Label>

      <Label fx:id="workoutFocus" styleClass="cell_small_label card-info">
        <graphic>
          <SVGPath styleClass="card-icon" scaleX="0.85" scaleY="0.85"
                   content="M8 1 L10 6 H15 L11 9 L13 15 L8 11 L3 15 L5 9 L1 6 H6 Z" />
        </graphic>
      </Label>

      <Label fx:id="remark" styleClass="cell_small_label card-info">
        <graphic>
          <SVGPath styleClass="card-icon" scaleX="0.85" scaleY="0.85"
                   content="M3 2 H13 A1 1 0 0 1 14 3 V11 A1 1 0 0 1 13 12 H7 L4 15 V12 H3 A1 1 0 0 1 2 11 V3 A1 1 0 0 1 3 2 Z M4 5 H12 V6 H4 Z M4 8 H10 V9 H4 Z" />
        </graphic>
      </Label>

      <Label fx:id="validity" styleClass="cell_small_label card-info">
        <graphic>
          <SVGPath styleClass="card-icon" scaleX="0.85" scaleY="0.85"
                   content="M4 2 V4 H12 V2 H14 V4 H15 C15.55 4 16 4.45 16 5 V15 C16 15.55 15.55 16 15 16 H1 C0.45 16 0 15.55 0 15 V5 C0 4.45 0.45 4 1 4 H2 V2 H4 Z M1 15 H15 V9 H1 V15 Z M1 7 H15 V5 H1 V7 Z" />
        </graphic>
      </Label>
    </VBox>
  </GridPane>
</HBox>
